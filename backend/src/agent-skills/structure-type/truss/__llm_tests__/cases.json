          }
        }
      }
    },
    {
      "scenarioId": "truss-extraction-zh",
      "category": "extraction",
      "locale": "zh",
      "messages": ["三角桁架，跨度12m，高3m，节点荷载20kN"],
      "variants": {
        "specific": {
          "enabledSkillIds": ["truss"],
          "fallbackPolicy": "forbid-generic",
