// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  avatar        String?
  organization  String?
  title         String?
  bio           String?
  expertise     String[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      Project[]
  conversations Conversation[]
  skills        Skill[]
  posts         Post[]
  comments      Comment[]
  reviews       SkillReview[]
  projectMemberships ProjectMember[]

  @@map("users")
}

// 项目表
model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  type        String
  location    Json?
  settings    Json?
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])
  members     ProjectMember[]
  models      StructuralModel[]
  skills      ProjectSkill[]

  @@map("projects")
}

// 项目成员
model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("project_members")
}

// 结构模型
model StructuralModel {
  id          String   @id @default(cuid())
  name        String
  description String?
  nodes       Json
  elements    Json
  materials   Json
  sections    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  analyses    Analysis[]
  createdBy   String?

  @@map("structural_models")
}

// 分析任务
model Analysis {
  id          String   @id @default(cuid())
  name        String
  type        String
  parameters  Json
  status      String   @default("pending")
  results     Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  modelId     String
  model       StructuralModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  createdBy   String?

  @@map("analyses")
}

// 对话
model Conversation {
  id        String    @id @default(cuid())
  title     String
  type      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  modelSnapshot    Json?
  resultSnapshot   Json?
  latestResult    Json?

  userId    String?
  user      User?     @relation(fields: [userId], references: [id])
  messages  Message[]

  @@map("conversations")
}

// 消息
model Message {
  id             String   @id @default(cuid())
  role           String
  content        String
  metadata       Json?
  tokenCount     Int?
  createdAt      DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// 技能
model Skill {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  version     String
  author      String
  tags        String[]
  config      Json
  isPublic    Boolean  @default(false)
  rating      Float    @default(0)
  installs    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId    String?
  authorUser  User?    @relation(fields: [authorId], references: [id])
  projects    ProjectSkill[]
  reviews     SkillReview[]
  executions  SkillExecution[]

  @@map("skills")
}

// 项目技能关联
model ProjectSkill {
  id        String   @id @default(cuid())
  projectId String
  skillId   String
  installedAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([projectId, skillId])
  @@map("project_skills")
}

// 技能评分
model SkillReview {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@unique([skillId, userId])
  @@map("skill_reviews")
}

// 技能执行记录
model SkillExecution {
  id         String   @id @default(cuid())
  parameters Json
  result     Json?
  createdAt  DateTime @default(now())

  skillId    String
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  userId     String?

  @@map("skill_executions")
}

// 社区帖子
model Post {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String
  tags        String[]
  attachments String[]
  viewCount   Int      @default(0)
  likeCount   Int      @default(0)
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  projectId   String?
  comments    Comment[]
  likes       PostLike[]

  @@map("posts")
}

// 帖子评论
model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  parentId  String?
  replies   Comment[] @relation("CommentReplies")
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])

  @@map("comments")
}

// 帖子点赞
model PostLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String

  @@unique([postId, userId])
  @@map("post_likes")
}
