# Shared environment variables for frontend, backend, scripts and docker compose.

# App/runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=30010
BACKEND_BODY_LIMIT_MB=20
LOG_LEVEL=info
LOG_MAX_AGE_DAYS=7
LOG_MAX_SIZE=104857600

# Frontend
FRONTEND_PORT=30000
NEXT_PUBLIC_API_URL=http://localhost:30010

# Database / cache
# Relative SQLite URLs are resolved against backend/prisma/schema.prisma and
# normalized to an absolute file path during local startup.
DATABASE_URL=file:../../.runtime/data/structureclaw.db
# Preserved automatically when doctor/startup migrates a legacy local PostgreSQL
# setup into SQLite. Leave blank for fresh installs.
POSTGRES_SOURCE_DATABASE_URL=
# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OpenAI-compatible LLM configuration
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
LLM_TIMEOUT_MS=180000
LLM_MAX_RETRIES=0

# Services
ANALYSIS_ENGINE_MANIFEST_PATH=
# Optional mirrors (used by Docker build and analysis setup).
# 留空则使用默认官方源；使用 sclaw_cn 时会自动注入国内默认值。
PIP_INDEX_URL=
NPM_CONFIG_REGISTRY=
DOCKER_REGISTRY_MIRROR=
APT_MIRROR=
# Optional override. Leave blank to use the platform default:
# Windows -> backend/.venv/Scripts/python.exe
# Unix-like -> backend/.venv/bin/python
ANALYSIS_PYTHON_BIN=
ANALYSIS_PYTHON_TIMEOUT_MS=300000
# Leave blank to auto-derive from FRONTEND_PORT and PORT.
CORS_ORIGINS=
# Optional override for Agent JSON/Markdown reports directory. Leave blank for
# <repo>/.runtime/reports (absolute path or repo-relative).
REPORTS_DIR=
MAX_FILE_SIZE=104857600

# LangGraph agent configuration
# Optional override for LangGraph checkpoint storage directory.
# Default: <repo>/.runtime/agent-checkpoints
AGENT_CHECKPOINT_DIR=
# Optional override for workspace root (agent file operations scope).
# Default: repository root
WORKSPACE_ROOT=
# Optional LangGraph agent shell tool. Disabled unless explicitly enabled.
AGENT_ALLOW_SHELL=false
AGENT_ALLOWED_SHELL_COMMANDS=node,npm,python,python3,./sclaw,./sclaw_cn
AGENT_SHELL_TIMEOUT_MS=300000

# LLM call logging (full prompt/response to .runtime/logs/llm-calls.jsonl)
LLM_LOG_ENABLED=true
LLM_LOG_DIR=
