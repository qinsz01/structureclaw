# Shared environment variables for frontend, backend, scripts and docker compose.

# App/runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=30010
LOG_LEVEL=info

# Frontend
FRONTEND_PORT=30000
NEXT_PUBLIC_API_URL=http://localhost:30010

# Database / cache
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/structureclaw
REDIS_URL=disabled

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# LLM provider selection: openai | zhipu | openai-compatible
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
LLM_TIMEOUT_MS=90000
LLM_MAX_RETRIES=0

# Optional compatibility / provider-specific keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_BASE_URL=https://api.openai.com/v1
ZAI_API_KEY=

# Services
CORE_PORT=30011
# Leave blank to auto-derive from CORE_PORT.
ANALYSIS_ENGINE_URL=
ANALYSIS_ENGINE_MANIFEST_PATH=
# Leave blank to auto-derive from FRONTEND_PORT and PORT.
CORS_ORIGINS=
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600
